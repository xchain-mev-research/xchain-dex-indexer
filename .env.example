# ---------------------------------------------------------------
# defi-data-importer — environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ---------------------------------------------------------------

# PostgreSQL connection
# Format: postgresql://<user>:<password>@<host>:<port>/
DB_URL_PREFIX=postgresql://postgres:password@localhost:5432/
DB_NAME=dex-indexer
DB_PORT=5432

# GraphQL server port
GQL_PORT=4350

# Moonbeam RPC endpoint (HTTP)
# Public endpoints: https://moonbeam-rpc.dwellir.com
#                   https://rpc.api.moonbeam.network
RPC_MOONBEAM_HTTP=https://moonbeam-rpc.dwellir.com

# Logging
# Set to "true" to write logs to file in addition to stdout
LOG_TO_FILE=false

# ---------------------------------------------------------------
# Optional: block range override for partial re-indexing.
# If not set, each importer starts from its factory deployment block.
# ---------------------------------------------------------------
# FROM_BLOCK=
# TO_BLOCK=

# ---------------------------------------------------------------
# Optional: dry run mode — set to "true" to run without writing to DB.
# ---------------------------------------------------------------
# DRY_RUN=false
