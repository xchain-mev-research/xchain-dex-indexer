{
  "name": "xchain-dex-indexer",
  "version": "1.0.0",
  "description": "High-granularity DEX indexer for EVM and Substrate blockchains. Per-block and intra-block pool snapshots, unified cross-protocol schema, data integrity verification against official subgraphs.",
  "keywords": [
    "polkadot",
    "moonbeam",
    "defi",
    "dex",
    "indexer",
    "subsquid",
    "uniswap",
    "algebra",
    "mev",
    "graphql"
  ],
  "author": "Alessio Giannini",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xchain-mev-research/xchain-dex-indexer"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "codegen:omni": "npx ts-node src/scripts/generate-omni-model.ts",
    "abi:gen": "node src/scripts/abi-gen.js",
    "start:gql": "PARACHAIN=moonbeam npx ts-node src/scripts/runGql.ts ",
    "integrityTest": "PARACHAIN=moonbeam npx ts-node src/scripts/runDataIntegrityTest.ts ",
    "start:moonbeam": "PARACHAIN=moonbeam npx ts-node src/scripts/run.ts ",
    "start:testChain": "PARACHAIN=testParachain npx ts-node src/scripts/run.ts "
  },
  "dependencies": {
    "@polkadot/api": "^15.9.2",
    "@polkadot/types": "^15.9.2",
    "@subsquid/archive-registry": "^3.3.2",
    "@subsquid/big-decimal": "^1.0.0",
    "@subsquid/evm-abi": "^0.3.1",
    "@subsquid/evm-processor": "^1.27.1",
    "@subsquid/graphql-server": "^4.11.0",
    "@subsquid/ss58": "^0.1.4",
    "@subsquid/substrate-processor": "^8.6.0",
    "@subsquid/typeorm-migration": "^1.3.0",
    "@subsquid/typeorm-store": "^1.5.1",
    "axios": "^1.8.4",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.5",
    "log4js": "^6.9.1",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "1.2.0-rc.1"
  },
  "devDependencies": {
    "@subsquid/evm-typegen": "4.4.0",
    "@subsquid/substrate-metadata-explorer": "^1.1.2",
    "@subsquid/substrate-typegen": "^2.2.1",
    "@subsquid/typeorm-codegen": "^2.0.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}